# FeatureFlow Environment Configuration
#
# Copy this file to .env and fill in the values for your environment.
# FeatureFlow is PostgreSQL-native. SQLite is NOT supported for integration tests.

# =============================================================================
# APPLICATION
# =============================================================================
PROJECT_NAME=FeatureFlow

# Environment: development | test | staging | production
ENVIRONMENT=development

LOG_LEVEL=INFO
DATA_DIR=./datasets

# =============================================================================
# DATABASE — PostgreSQL REQUIRED
# =============================================================================
# Replace <user>, <password>, <host>, <port>, <dbname> with your PostgreSQL credentials.
# For local development: createdb featureflow_test
# For CI: provisioned automatically via GitHub Actions services.
# NEVER point this at the production database when running tests.
#
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>

# =============================================================================
# REDIS
# =============================================================================
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# SECURITY — OVERRIDE ALL DEFAULTS IN PRODUCTION
# =============================================================================
# JWT_SECRET_KEYS=<generate-with: openssl rand -hex 32>
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# DEFAULT_ADMIN_EMAIL=admin@featureflow.local
# DEFAULT_ADMIN_PASSWORD=<strong-password>
# BCRYPT_ROUNDS=12

# =============================================================================
# FRONTEND
# =============================================================================
# VITE_API_URL=http://localhost:8000/api/v1
# CORS_ORIGINS=http://localhost:3000
